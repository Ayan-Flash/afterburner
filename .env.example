# GPUControl Pro Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=GPUControl Pro
APP_ENV=development
APP_DEBUG=true

# Tauri
TAURI_DEV_HOST=localhost
TAURI_DEV_PORT=1420

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/gpucontrol.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Monitoring
MONITORING_SAMPLE_RATE_MS=1000
MONITORING_BUFFER_SIZE=3600
MONITORING_RETENTION_HOURS=24

# Update
UPDATE_CHECK_INTERVAL_HOURS=24
UPDATE_CHANNEL=stable

# Features
FEATURE_OVERLAY=false
FEATURE_REMOTE_MONITORING=false
