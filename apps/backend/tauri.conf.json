{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "GPUControl Pro",
  "version": "0.2.0",
  "identifier": "pro.gpucontrol.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd ..\\frontend && pnpm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Armoury Crate",
        "width": 1024,
        "height": 600,
        "minWidth": 960,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability set for GPUControl Pro",
          "windows": ["main", "overlay"],
          "permissions": [
            "core:default",
            "core:window:allow-minimize",
            "core:window:allow-unminimize",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-is-maximized",
            "core:window:allow-close",
            "core:window:allow-destroy",
            "core:window:allow-show",
            "core:window:allow-hide",
            "core:window:allow-set-focus",
            "core:window:allow-start-dragging",
            "shell:allow-open",
            "notification:default",
            "notification:allow-notify",
            "dialog:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "global-shortcut:default",
            "global-shortcut:allow-register",
            "global-shortcut:allow-unregister",
            "process:default",
            "process:allow-exit",
            "fs:default",
            "fs:allow-read",
            "fs:allow-write",
            "updater:default",
            "updater:allow-check",
            "updater:allow-install"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "YOUR_UPDATER_SIGNATURE_PUBKEY_HERE",
      "endpoints": [
        "https://releases.gpucontrol.pro/{{target}}/{{current_version}}",
        "https://github.com/gpucontrol-pro/gpucontrol-pro/releases/latest/download/update-{{target}}-{{current_version}}.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
