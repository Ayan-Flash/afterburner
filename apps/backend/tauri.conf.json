{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "GPUControl Pro",
  "version": "0.2.0",
  "identifier": "pro.gpucontrol.app",
  "build": {
    "beforeBuildCommand": "cd apps/frontend && npm run build",
    "beforeDevCommand": "cd apps/frontend && npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "GPUControl Pro",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability set for GPUControl Pro",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "notification:default",
            "notification:allow-notify",
            "dialog:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "global-shortcut:default",
            "global-shortcut:allow-register",
            "global-shortcut:allow-unregister",
            "process:default",
            "process:allow-exit",
            "fs:default",
            "fs:allow-read",
            "fs:allow-write"
          ]
        }
      ]
    },
    "trayIcon": {
      "iconPath": "assets/icons/png/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/icons/png/32x32.png",
      "assets/icons/png/128x128.png",
      "assets/icons/png/128x128@2x.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://releases.gpucontrol.pro/{{target}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "notification": {
      "all": true
    },
    "global-shortcut": {
      "shortcuts": [
        {
          "key": "Ctrl+Shift+O",
          "description": "Toggle overlay visibility"
        }
      ]
    }
  }
}
