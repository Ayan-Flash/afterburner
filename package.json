{
  "name": "gpucontrol-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Professional GPU Monitoring & Control for Windows",
  "scripts": {
    "dev": "pnpm --filter gpucontrol-pro-frontend dev",
    "build": "pnpm --filter gpucontrol-pro-frontend build && cd apps/backend && npx tauri build",
    "lint": "pnpm lint:frontend && pnpm lint:backend",
    "lint:frontend": "pnpm --filter gpucontrol-pro-frontend lint",
    "lint:backend": "cd apps/backend && cargo clippy",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "typecheck": "pnpm --filter gpucontrol-pro-frontend typecheck",
    "test": "pnpm test:frontend && pnpm test:backend",
    "test:frontend": "pnpm --filter gpucontrol-pro-frontend test",
    "test:backend": "cd apps/backend && cargo test",
    "check": "pnpm lint && pnpm typecheck",
    "clean": "rm -rf apps/frontend/dist apps/backend/target",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=7"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "@eslint/js": "^8.57.1",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.10.0"
}
